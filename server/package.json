{
  "name": "blancbleu-server",
  "version": "1.3.0",
  "description": "Backend API - Plateforme BlancBleu",
  "main": "Server.js",
  "scripts": {
    "start": "node Server.js",
    "dev": "nodemon Server.js",
    "create-admin": "node scripts/create-admin.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=__tests__/unit --runInBand --forceExit",
    "test:integration": "jest --testPathPattern=__tests__/integration --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testPathIgnorePatterns": ["/node_modules/", "/_deprecated/"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "services/**/*.js",
      "controllers/**/*.js",
      "middleware/**/*.js",
      "utils/**/*.js",
      "!services/simulationService.js",
      "!utils/logger.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 40,
        "branches": 30,
        "functions": 33,
        "lines": 40
      },
      "./services/stateMachine.js": {
        "branches": 80,
        "functions": 95,
        "lines": 90
      },
      "./middleware/Auth.js": {
        "branches": 85,
        "functions": 100,
        "lines": 90
      },
      "./middleware/auditMiddleware.js": {
        "lines": 95
      },
      "./services/escaladeService.js": {
        "functions": 25,
        "lines": 35
      },
      "./utils/geoUtils.js": {
        "functions": 60,
        "lines": 65
      }
    }
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "socket.io": "^4.6.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.19.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.4.1",
    "nodemon": "^3.0.2",
    "supertest": "^7.0.0"
  }
}
