# ══════════════════════════════════════════════════════════════════════════════
# BlancBleu Patient — Variables d'environnement Flutter
# Copier : cp .env.example .env
# Ne JAMAIS committer le .env réel — ajouté au .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ─── API Backend ──────────────────────────────────────────────────────────────
# Émulateur Android  → http://10.0.2.2:5000/api/patient
# Appareil physique  → http://<IP_DE_VOTRE_MACHINE>:5000/api/patient
# Production         → https://api.blancbleu.fr/api/patient
API_BASE_URL=http://10.0.2.2:5000/api/patient

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Clé PUBLIQUE uniquement (pk_test_* ou pk_live_*)
# Obtenir depuis : https://dashboard.stripe.com/apikeys
# NE JAMAIS mettre la clé secrète (sk_*) dans le client mobile
STRIPE_PUBLISHABLE_KEY=pk_test_REMPLACER_PAR_VOTRE_CLE
