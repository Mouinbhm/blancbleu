# ══════════════════════════════════════════════════════
# BlancBleu — Variables d'environnement
# Copier : cp .env.example .env
# Ne jamais committer le .env réel
# ══════════════════════════════════════════════════════

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/blancbleu
MONGO_USER=blancbleu
MONGO_PASSWORD=blancbleu2024

# ─── JWT ──────────────────────────────────────────────
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_STRONG_64_CHAR_SECRET

# ─── Serveur ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Module IA Flask ──────────────────────────────────
AI_API_URL=http://localhost:5001

# ─── Email (reset password) ───────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre-email@gmail.com
EMAIL_PASS=votre-app-password-gmail
EMAIL_FROM=BlancBleu <noreply@blancbleu.fr>

# ─── Premier admin (script create-admin uniquement) ───
# Retirer après exécution de : npm run create-admin
ADMIN_EMAIL=admin@blancbleu.fr
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_NOM=Admin
ADMIN_PRENOM=BlancBleu